<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keyboard_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/keyboard_background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/gallery_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Art Gallery 🎨"
            app:titleTextColor="@color/key_text_color"
            app:titleCentered="true"
            app:navigationIcon="?attr/homeAsUpIndicator"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Mock Premium Upgrade Banner -->
        <androidx.cardview.widget.CardView
            android:id="@+id/banner_premium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/toolbar_background"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Unlock all Premium styles, layouts and custom features! 👑"
                    android:textColor="@color/key_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btn_unlock_premium"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unlock"
                    android:textColor="@color/key_text_color"
                    app:backgroundTint="@color/accent_color"
                    android:layout_marginLeft="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Search Bar -->
        <EditText
            android:id="@+id/et_gallery_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="Search 36+ styles..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/key_text_color"
            android:backgroundTint="@color/accent_color"
            android:textSize="14sp"
            android:inputType="text"/>

        <!-- Category Scroll View -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:id="@+id/tab_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:textColor="@color/key_text_color" android:textSize="12sp" android:background="@drawable/chip_active_background" android:clickable="true" android:focusable="true" android:layout_marginRight="8dp"/>
                <TextView android:id="@+id/tab_classic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Classic" android:textColor="@color/key_text_color" android:textSize="12sp" android:background="@drawable/chip_inactive_background" android:clickable="true" android:focusable="true" android:layout_marginRight="8dp"/>
                <TextView android:id="@+id/tab_symbol" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Symbol" android:textColor="@color/key_text_color" android:textSize="12sp" android:background="@drawable/chip_inactive_background" android:clickable="true" android:focusable="true" android:layout_marginRight="8dp"/>
                <TextView android:id="@+id/tab_emoji" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emoji" android:textColor="@color/key_text_color" android:textSize="12sp" android:background="@drawable/chip_inactive_background" android:clickable="true" android:focusable="true" android:layout_marginRight="8dp"/>
                <TextView android:id="@+id/tab_favorites" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Favorites" android:textColor="@color/key_text_color" android:textSize="12sp" android:background="@drawable/chip_inactive_background" android:clickable="true" android:focusable="true" android:layout_marginRight="8dp"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Recycler View -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_gallery_styles"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:listitem="@layout/item_art_gallery_style"/>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
