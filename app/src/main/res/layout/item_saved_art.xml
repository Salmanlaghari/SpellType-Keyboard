<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/key_special_normal"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_style_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STYLE: BOX"
                android:textColor="@color/accent_color"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#EF4444"
                android:textSize="16dp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_original_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Original: Hello"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-light"/>

        <TextView
            android:id="@+id/tv_styled_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="┌───────┐\n│ Hello │\n└───────┘"
            android:textColor="@color/key_text_color"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:background="#05070C"
            android:padding="12dp"
            android:scrollHorizontally="true"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
