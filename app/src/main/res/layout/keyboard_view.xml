<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:paddingBottom="4dp">

    <!-- Sponsored Ad Banner -->
    <LinearLayout
        android:id="@+id/keyboard_ad_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FEF08A"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" [AD] "
            android:textColor="#92400E"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="#FEF3C7"
            android:padding="2dp"
            android:layout_marginRight="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Upgrade to Premium for AD-FREE Custom Fonts! 👑"
            android:textColor="#78350F"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/btn_close_keyboard_ad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#78350F"
            android:textSize="12sp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Active Frame Selector Toolbar / Quick Art Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/toolbar_background"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SpellType 🪄"
            android:textColor="@color/key_text_color"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginRight="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/quick_art_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <!-- Programmatically populated with style chips at runtime -->
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Pro Tools Floating Bar -->
    <LinearLayout
        android:id="@+id/pro_tools_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#1B1F2D"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛠️ Pro Tools: "
            android:textColor="@color/accent_color"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginRight="4dp"/>

        <TextView
            android:id="@+id/tool_clipboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Clipboard"
            android:textColor="@color/key_text_color"
            android:textSize="12sp"
            android:background="@drawable/chip_inactive_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginRight="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tool_translate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 Translate"
            android:textColor="@color/key_text_color"
            android:textSize="12sp"
            android:background="@drawable/chip_inactive_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginRight="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tool_templates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Bios"
            android:textColor="@color/key_text_color"
            android:textSize="12sp"
            android:background="@drawable/chip_inactive_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Auto-Suggestions Bar -->
    <LinearLayout
        android:id="@+id/auto_suggestions_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#111827"
        android:gravity="center_vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/suggestion_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:text="spell"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#374151"/>

        <TextView
            android:id="@+id/suggestion_center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:gravity="center"
            android:textColor="@color/key_text_color"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="SpellType"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#374151"/>

        <TextView
            android:id="@+id/suggestion_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:text="keyboard"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Live Preview Bar -->
    <TextView
        android:id="@+id/tv_keyboard_live_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#05070C"
        android:textColor="@color/key_text_color"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        android:text="Preview goes here"/>

    <!-- Permanent Number Row -->
    <LinearLayout
        android:id="@+id/number_row"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp"
        android:layout_marginTop="2dp"
        android:visibility="visible">

        <TextView android:id="@+id/num_1" style="@style/KeyboardKey" android:text="1" android:textSize="16sp"/>
        <TextView android:id="@+id/num_2" style="@style/KeyboardKey" android:text="2" android:textSize="16sp"/>
        <TextView android:id="@+id/num_3" style="@style/KeyboardKey" android:text="3" android:textSize="16sp"/>
        <TextView android:id="@+id/num_4" style="@style/KeyboardKey" android:text="4" android:textSize="16sp"/>
        <TextView android:id="@+id/num_5" style="@style/KeyboardKey" android:text="5" android:textSize="16sp"/>
        <TextView android:id="@+id/num_6" style="@style/KeyboardKey" android:text="6" android:textSize="16sp"/>
        <TextView android:id="@+id/num_7" style="@style/KeyboardKey" android:text="7" android:textSize="16sp"/>
        <TextView android:id="@+id/num_8" style="@style/KeyboardKey" android:text="8" android:textSize="16sp"/>
        <TextView android:id="@+id/num_9" style="@style/KeyboardKey" android:text="9" android:textSize="16sp"/>
        <TextView android:id="@+id/num_0" style="@style/KeyboardKey" android:text="0" android:textSize="16sp"/>
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp"
        android:layout_marginTop="2dp">

        <TextView android:id="@+id/btn_q" style="@style/KeyboardKey" android:text="q"/>
        <TextView android:id="@+id/btn_w" style="@style/KeyboardKey" android:text="w"/>
        <TextView android:id="@+id/btn_e" style="@style/KeyboardKey" android:text="e"/>
        <TextView android:id="@+id/btn_r" style="@style/KeyboardKey" android:text="r"/>
        <TextView android:id="@+id/btn_t" style="@style/KeyboardKey" android:text="t"/>
        <TextView android:id="@+id/btn_y" style="@style/KeyboardKey" android:text="y"/>
        <TextView android:id="@+id/btn_u" style="@style/KeyboardKey" android:text="u"/>
        <TextView android:id="@+id/btn_i" style="@style/KeyboardKey" android:text="i"/>
        <TextView android:id="@+id/btn_o" style="@style/KeyboardKey" android:text="o"/>
        <TextView android:id="@+id/btn_p" style="@style/KeyboardKey" android:text="p"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView android:id="@+id/btn_a" style="@style/KeyboardKey" android:text="a"/>
        <TextView android:id="@+id/btn_s" style="@style/KeyboardKey" android:text="s"/>
        <TextView android:id="@+id/btn_d" style="@style/KeyboardKey" android:text="d"/>
        <TextView android:id="@+id/btn_f" style="@style/KeyboardKey" android:text="f"/>
        <TextView android:id="@+id/btn_g" style="@style/KeyboardKey" android:text="g"/>
        <TextView android:id="@+id/btn_h" style="@style/KeyboardKey" android:text="h"/>
        <TextView android:id="@+id/btn_j" style="@style/KeyboardKey" android:text="j"/>
        <TextView android:id="@+id/btn_k" style="@style/KeyboardKey" android:text="k"/>
        <TextView android:id="@+id/btn_l" style="@style/KeyboardKey" android:text="l"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp">

        <TextView android:id="@+id/btn_shift" style="@style/KeyboardKey.Special" android:layout_weight="1.5" android:text="⇧"/>
        <TextView android:id="@+id/btn_z" style="@style/KeyboardKey" android:text="z"/>
        <TextView android:id="@+id/btn_x" style="@style/KeyboardKey" android:text="x"/>
        <TextView android:id="@+id/btn_c" style="@style/KeyboardKey" android:text="c"/>
        <TextView android:id="@+id/btn_v" style="@style/KeyboardKey" android:text="v"/>
        <TextView android:id="@+id/btn_b" style="@style/KeyboardKey" android:text="b"/>
        <TextView android:id="@+id/btn_n" style="@style/KeyboardKey" android:text="n"/>
        <TextView android:id="@+id/btn_m" style="@style/KeyboardKey" android:text="m"/>
        <TextView android:id="@+id/btn_backspace" style="@style/KeyboardKey.Special" android:layout_weight="1.5" android:text="⌫"/>
    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp">

        <TextView android:id="@+id/btn_mode" style="@style/KeyboardKey.Special" android:layout_weight="1.5" android:text="\?123"/>
        <TextView android:id="@+id/btn_space" style="@style/KeyboardKey" android:layout_weight="5" android:text=""/>
        <TextView android:id="@+id/btn_enter" style="@style/KeyboardKey.Accent" android:layout_weight="2" android:text="Enter"/>
    </LinearLayout>

</LinearLayout>
