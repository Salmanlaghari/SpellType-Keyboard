<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/key_special_normal"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_style_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STYLE: STAR"
                android:textColor="@color/accent_color"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <!-- Premium Lock Icon -->
            <TextView
                android:id="@+id/tv_premium_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑 Premium"
                android:textColor="#FBBF24"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginRight="12dp"
                android:visibility="gone"/>

            <!-- Favorite Pin Heart -->
            <TextView
                android:id="@+id/btn_favorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textColor="#EF4444"
                android:textSize="20sp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Dynamic Monospace Preview -->
        <TextView
            android:id="@+id/tv_style_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="★★★★★★★★★\n★ Preview ★\n★★★★★★★★★"
            android:textColor="@color/key_text_color"
            android:textSize="13sp"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:background="#05070C"
            android:padding="12dp"
            android:gravity="center"
            android:scrollHorizontally="true"/>

        <!-- Action Row (Copy and Share) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="right">

            <Button
                android:id="@+id/btn_copy"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy"
                android:textColor="@color/key_text_color"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/key_text_color"/>

            <Button
                android:id="@+id/btn_share"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:textColor="@color/key_text_color"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="@color/key_text_color"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
