<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.spelltype.keyboard">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="SpellType Keyboard"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpellType">

        <!-- Keyboard IME Service -->
        <service
            android:name=".presentation.ime.SpellTypeIME"
            android:label="SpellType Keyboard"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Settings Activity -->
        <activity
            android:name=".presentation.settings.SettingsActivity"
            android:exported="true"
            android:theme="@style/Theme.SpellType">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Art Gallery Activity -->
        <activity
            android:name=".presentation.settings.ArtGalleryActivity"
            android:exported="false"
            android:theme="@style/Theme.SpellType" />

    </application>
</manifest>
